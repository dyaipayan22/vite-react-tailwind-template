{
  "name": "vite-react-tailwind-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{js,jsx,json,ts,tsx,css,md}\"",
    "check-format": "prettier --check \"**/*.{js,jsx,json,ts,tsx,css,md}\""
  },
  "dependencies": {
